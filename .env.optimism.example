# Template for the Optimism bot — copy to .env.optimism and fill in.
# Use a FRESH key holding only a small gas float (~0.002 ETH). Never reuse
# the Base key: one hot key per chain caps the blast radius.

BASE_RPC_URL=https://mainnet.optimism.io
PRIVATE_KEY=0xREPLACE_ME_NEW_KEY_SMALL_FLOAT_ONLY

CHAIN_ID=10
L1_FEE=oracle              # Optimism is OP-stack — same L1 fee oracle as Base

# Start in dry-run. Flip to true yourself only after watching a few clean scans.
EXECUTE=false

SCAN_INTERVAL_MS=60000
MAX_GAS_GWEI=0.5
MIN_REWARD_WEI=0
MIN_NET_PROFIT_WEI=0
GAS_SAFETY_MULTIPLIER=1.2
LOG_LEVEL=info

# Optional — reuse the same Telegram bot, or leave empty to disable.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
